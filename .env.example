# App
APP_NAME=MTBank AI Transcription
ENVIRONMENT=dev
DEBUG=true
API_V1_PREFIX=/api/v1
HEALTH_PATH=/health

# Logging
LOG_FORMAT=json
LOG_LEVEL=INFO

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ASR defaults, implemented in later stages
WHISPER_MODEL=medium
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=int8_float16
WHISPER_CPU_THREADS=0
WHISPER_NUM_WORKERS=1
WHISPER_BEAM_SIZE=1
WHISPER_BATCH_SIZE=8
WHISPER_LANGUAGE=ru
WHISPER_VAD_FILTER=true
WHISPER_WORD_TIMESTAMPS=false
WHISPER_CONDITION_ON_PREVIOUS_TEXT=false
WHISPER_DOWNLOAD_ROOT=
WHISPER_LOCAL_FILES_ONLY=false
PRELOAD_ASR_MODEL=true

# Audio ingestion, implemented in the audio stage
MAX_AUDIO_MB=100
MAX_AUDIO_SECONDS=600
ALLOWED_AUDIO_EXTENSIONS=.wav,.mp3,.ogg,.m4a,.flac,.mp4
AUDIO_STORAGE_BACKEND=local
AUDIO_STORAGE_DIR=var/audio
AUDIO_NORMALIZED_SAMPLE_RATE=16000
AUDIO_NORMALIZED_CHANNELS=1

# Diarization defaults, implemented in later stages
DIARIZATION_BACKEND=fallback
HF_TOKEN=

# OpenAI-compatible LLM, implemented in later stages
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=
