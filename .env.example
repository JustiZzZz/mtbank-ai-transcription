# App
APP_NAME=MTBank AI Transcription
ENVIRONMENT=dev
DEBUG=true
API_V1_PREFIX=/api/v1
HEALTH_PATH=/health

# Logging
LOG_FORMAT=json
LOG_LEVEL=INFO

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ASR defaults, implemented in later stages
WHISPER_MODEL=medium
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=int8_float16
WHISPER_BEAM_SIZE=1
WHISPER_LANGUAGE=ru
WHISPER_VAD_FILTER=true

# Diarization defaults, implemented in later stages
DIARIZATION_BACKEND=fallback
HF_TOKEN=

# OpenAI-compatible LLM, implemented in later stages
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=

