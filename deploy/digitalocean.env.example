# DigitalOcean production example.
# Copy to .env on the Droplet and fill real secrets before starting compose.

# Public HTTPS endpoint.
# Option A: a real domain/subdomain, e.g. mtbank-demo.example.com.
# Option B without a domain: <DROPLET_IP>.sslip.io, e.g. 203.0.113.10.sslip.io.
DOMAIN=
ACME_EMAIL=

# App
APP_NAME=MTBank AI Transcription
ENVIRONMENT=production
DEBUG=false
LOG_FORMAT=json
LOG_LEVEL=INFO
CORS_ORIGINS=https://${DOMAIN}

# ASR
WHISPER_MODEL=medium
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_CPU_THREADS=0
WHISPER_NUM_WORKERS=1
WHISPER_BEAM_SIZE=1
WHISPER_BATCH_SIZE=16
WHISPER_LANGUAGE=ru
WHISPER_VAD_FILTER=true
WHISPER_WORD_TIMESTAMPS=false
WHISPER_CONDITION_ON_PREVIOUS_TEXT=false
WHISPER_LOCAL_FILES_ONLY=false

# Keep false on small CPU droplets to avoid slow boot loops.
# Set true only after the model cache is warmed and the Droplet has enough RAM.
API_PRELOAD_ASR_MODEL=false
PIPELINES_PRELOAD_ASR_MODEL=false

# Audio ingestion
MAX_AUDIO_MB=100
MAX_AUDIO_SECONDS=600
ALLOWED_AUDIO_EXTENSIONS=.wav,.mp3,.ogg,.m4a,.flac,.mp4
AUDIO_STORAGE_BACKEND=local
AUDIO_STORAGE_DIR=/app/var/audio
AUDIO_NORMALIZED_SAMPLE_RATE=16000
AUDIO_NORMALIZED_CHANNELS=1

# Diarization
DIARIZATION_BACKEND=fallback
HF_TOKEN=

# Qwen OpenAI-compatible LLM. Do not commit real keys.
LLM_ENABLED=true
OPENAI_BASE_URL=https://llm-pnv5fw3uqyar1tdu.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1
OPENAI_API_KEY=
OPENAI_MODEL=qwen3.7-plus
LLM_TEMPERATURE=0
LLM_TIMEOUT_SECONDS=60
LLM_MAX_OUTPUT_TOKENS=1200
LLM_ENABLE_THINKING=false
LLM_JSON_MODE=true
LLM_VALIDATION_RETRIES=1

# OpenWebUI / Pipelines
PIPELINES_API_KEY=
WEBUI_AUTH=True
ENABLE_PERSISTENT_CONFIG=False
OPENWEBUI_BYPASS_PYDUB_PREPROCESSING=true
OPENWEBUI_WHISPER_MODEL=base
OPENWEBUI_WHISPER_COMPUTE_TYPE=int8
OPENWEBUI_WHISPER_LANGUAGE=ru
OPENWEBUI_WHISPER_VAD_FILTER=true
OPENWEBUI_AUDIO_STT_ALLOWED_EXTENSIONS=mp3,wav,m4a,webm,ogg,flac,mp4,mpga,mpeg
